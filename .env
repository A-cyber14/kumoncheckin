# ─── Gmail Sender Account ──────────────────────────────────────────────────────
# The Gmail address that will SEND the alert email
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com → Security
#   2. Turn on 2-Step Verification (required)
#   3. Search "App Passwords" → create one → copy the 16-character code here
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Alert Recipient ───────────────────────────────────────────────────────────
# The email address where the 45-minute alert will be sent (can be the same Gmail)
ALERT_EMAIL=your_email@gmail.com

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
